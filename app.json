{
  "expo": {
    "name": "Ehliyet Hocam – AI Destekli Eğitim",
    "slug": "ehliyet-hocam",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "ehliyet-sinavi",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ehliyet.ai.sinav",
      "usesAppleSignIn": true,
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDisplayName": "Ehliyet Hocam",
        "NSCameraUsageDescription": "Uygulama, profil fotoğrafınızı güncellemek için kameraya erişim gerektirir.",
        "NSPhotoLibraryUsageDescription": "Uygulama, profil fotoğrafınızı seçmek için fotoğraf galerinize erişim gerektirir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ehliyet.ai.sinav",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "7c48f854-bd8d-4a1b-b36b-6d1ddb46b4f4"
      }
    }
  }
}